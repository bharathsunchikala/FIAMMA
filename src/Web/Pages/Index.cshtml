@page
@model IndexModel
@using BlazorShared.Authorization
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Fiamma";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<section class="fiamma-home">
    <section class="fiamma-announcement fiamma-reveal">
        <div class="fiamma-announcement-window">
            <div class="fiamma-announcement-track" data-announcement-track>
                <p>Free shipping in India on all orders over Rs. 1,500.</p>
                <p>Fresh FIAMMA arrivals are added every week.</p>
                <p>Worldwide shipping is available for every Fiamma order.</p>
            </div>
        </div>
    </section>

    <nav class="fiamma-nav">
        <a class="fiamma-logo fiamma-logo--nav" asp-page="/Index">
            <img class="fiamma-logo-image" src="~/images/brand/fiamma-logo.png" alt="Fiamma logo" />
        </a>
        <div class="fiamma-nav-links">
            <a asp-page="/Index" asp-route-search="new">New Arrivals</a>
            <a asp-page="/Index" asp-route-collection="tshirts" asp-route-pageId="0" asp-fragment="products">T-Shirts</a>
            <a asp-page="/Index" asp-route-collection="bottoms" asp-route-pageId="0" asp-fragment="products">Bottoms</a>
            <a asp-page="/Index" asp-route-collection="jackets" asp-route-pageId="0" asp-fragment="products">Jackets</a>
        </div>
        <a class="fiamma-basket-button" asp-page="/Basket/Index">Basket</a>
    </nav>

    <section class="fiamma-hero fiamma-reveal">
        <div class="fiamma-hero-copy">
            <p class="fiamma-eyebrow">Fiamma Studio</p>
            <h1>FIAMMA fashion for everyday moments.</h1>
            <p class="fiamma-subtitle">Discover original products, build your basket, and launch your own curated catalog in one place.</p>
            <div class="fiamma-hero-actions">
                <a asp-page="/Index" asp-route-search="new">Shop New Arrivals</a>
                <a asp-page="/Index" asp-route-collection="jackets" asp-route-pageId="0" asp-fragment="products">Explore Jackets</a>
            </div>
        </div>
    </section>

    <section class="fiamma-search-panel fiamma-reveal">
        <h2>Search the catalog</h2>
        <form method="get" class="fiamma-search">
            <input type="search" name="search" value="@Model.CatalogModel.Search" placeholder="Search by keyword, style, or occasion..." />
            <select name="brandFilterApplied">
                @foreach (var brand in Model.CatalogModel.Brands ?? Enumerable.Empty<SelectListItem>())
                {
                    var selected = brand.Value == Model.CatalogModel.BrandFilterApplied?.ToString() ? "selected" : null;
                    <option value="@brand.Value" selected="@selected">@brand.Text</option>
                }
            </select>
            <select name="typesFilterApplied">
                @foreach (var type in Model.CatalogModel.Types ?? Enumerable.Empty<SelectListItem>())
                {
                    var selected = type.Value == Model.CatalogModel.TypesFilterApplied?.ToString() ? "selected" : null;
                    <option value="@type.Value" selected="@selected">@type.Text</option>
                }
            </select>
            <button type="submit">Search</button>
        </form>
    </section>

    <section class="fiamma-collections fiamma-reveal">
        <header>
            <h2>Collections</h2>
            <p>Use quick routes to jump into curated product families.</p>
        </header>
        <div class="fiamma-collection-grid">
            <a class="fiamma-collection-card fiamma-collection-card--tshirts" asp-page="/Index" asp-route-collection="tshirts" asp-route-pageId="0" asp-fragment="products">
                <div class="fiamma-collection-mosaic" aria-hidden="true">
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-ember-pocket-tee.png" alt="" />
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-crimson-classic-tee.png" alt="" />
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-electric-flame-tee.png" alt="" />
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-inferno-graphic-tee.png" alt="" />
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-midnight-polo-shirt.png" alt="" />
                </div>
                <span>01</span>
                <strong>T-Shirts</strong>
            </a>
            <a class="fiamma-collection-card fiamma-collection-card--bottoms" asp-page="/Index" asp-route-collection="bottoms" asp-route-pageId="0" asp-fragment="products">
                <div class="fiamma-collection-mosaic" aria-hidden="true">
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-frost-cargo-bottoms.png" alt="" />
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-graphite-utility-bottoms.png" alt="" />
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-mocha-cargo-bottoms.png" alt="" />
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-shadow-cargo-bottoms.png" alt="" />
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-mocha-cargo-bottoms.png" alt="" />
                </div>
                <span>02</span>
                <strong>Bottoms</strong>
            </a>
            <a class="fiamma-collection-card fiamma-collection-card--jackets" asp-page="/Index" asp-route-collection="jackets" asp-route-pageId="0" asp-fragment="products">
                <div class="fiamma-collection-mosaic" aria-hidden="true">
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-obsidian-hooded-jacket.png" alt="" />
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-olive-ridge-jacket.png" alt="" />
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-storm-navy-jacket.png" alt="" />
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-olive-ridge-jacket.png" alt="" />
                    <img class="fiamma-collection-image" src="~/images/products/fiamma-storm-navy-jacket.png" alt="" />
                </div>
                <span>03</span>
                <strong>Jackets</strong>
            </a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <section class="fiamma-status-message fiamma-reveal">@Model.StatusMessage</section>
    }

    @if (isAuthenticated)
    {
        <section class="fiamma-manage-products fiamma-reveal">
            <h2>Add Product</h2>
            <p>Create a new product by setting its name and price.</p>
            <form method="post" asp-page-handler="CreateProduct" class="fiamma-manage-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input asp-for="NewProduct.Name" placeholder="Product name" />
                <input asp-for="NewProduct.Price" type="number" min="0.01" step="0.01" placeholder="Price" />
                <select asp-for="NewProduct.CatalogTypeId">
                    <option value="">Choose category</option>
                    @foreach (var type in Model.AvailableTypes)
                    {
                        <option value="@type.Value">@type.Text</option>
                    }
                </select>
                <select asp-for="NewProduct.CatalogBrandId">
                    <option value="">Choose brand</option>
                    @foreach (var brand in Model.AvailableBrands)
                    {
                        <option value="@brand.Value">@brand.Text</option>
                    }
                </select>
                <input asp-for="NewProduct.Description" placeholder="Description (optional)" />
                <input asp-for="NewProduct.PictureUri" placeholder="Image path (optional)" />
                <button type="submit">Add Product</button>
            </form>
        </section>
    }

    <section id="products" class="fiamma-products fiamma-reveal">
        <header class="fiamma-products-header">
            <h2>Featured Products</h2>
            <p>Add items to basket directly from this showcase.</p>
        </header>
        @if (Model.CatalogModel.CatalogItems.Any())
        {
            <partial name="_pagination" for="CatalogModel.PaginationInfo" />
            <div class="fiamma-rail-controls">
                <button type="button" data-scroll-dir="-1" aria-label="Scroll products left">&#8592;</button>
                <button type="button" data-scroll-dir="1" aria-label="Scroll products right">&#8594;</button>
            </div>
            <div class="fiamma-product-scroller" data-product-scroller>
                @foreach (var catalogItem in Model.CatalogModel.CatalogItems)
                {
                    <article class="fiamma-product-slide">
                        <partial name="_product" for="@catalogItem" />
                    </article>
                }
            </div>
            <partial name="_pagination" for="CatalogModel.PaginationInfo" />
        }
        else
        {
            <div class="fiamma-no-results">No products matched your search.</div>
        }
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function updateSelectedOptions(form) {
                const hiddenInput = form.querySelector(".selected-options-json");
                if (!hiddenInput) return;

                const selected = Array.from(form.querySelectorAll(".option-radio:checked")).map((option) => ({
                    productOptionId: parseInt(option.dataset.optionId || "0"),
                    type: option.dataset.optionType || "",
                    value: option.value || "",
                    displayName: option.dataset.displayName || "",
                    additionalPrice: parseFloat(option.dataset.additionalPrice || "0")
                }));

                hiddenInput.value = JSON.stringify(selected);
            }

            document.addEventListener("change", (event) => {
                if (!event.target.classList.contains("option-radio")) return;
                const form = event.target.closest(".product-form");
                if (form) updateSelectedOptions(form);
            });

            document.addEventListener("submit", (event) => {
                const form = event.target.closest(".product-form");
                if (form) updateSelectedOptions(form);
            });

            const revealElements = document.querySelectorAll(".fiamma-reveal");
            if ("IntersectionObserver" in window) {
                const revealObserver = new IntersectionObserver((entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("is-visible");
                            revealObserver.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.12 });

                revealElements.forEach((element) => revealObserver.observe(element));
            } else {
                revealElements.forEach((element) => element.classList.add("is-visible"));
            }

            const announcementTrack = document.querySelector("[data-announcement-track]");
            if (announcementTrack) {
                const total = announcementTrack.children.length;
                let index = 0;

                setInterval(() => {
                    index = (index + 1) % total;
                    announcementTrack.style.transform = `translateY(-${index * 100}%)`;
                }, 3600);
            }

            const productScroller = document.querySelector("[data-product-scroller]");
            if (productScroller) {
                document.querySelectorAll("[data-scroll-dir]").forEach((button) => {
                    button.addEventListener("click", () => {
                        const direction = parseInt(button.getAttribute("data-scroll-dir") || "1", 10);
                        productScroller.scrollBy({
                            left: direction * productScroller.clientWidth * 0.85,
                            behavior: "smooth"
                        });
                    });
                });
            }
        })();
    </script>
}
